# Atomic Linux - Base Image
# Builds a minimal, hardened, bootable OCI image.
#
# Foundation stack:
#   - Project Hummingbird: provides the zero-CVE minimal content philosophy.
#     When Red Hat publishes official Hummingbird base images they will replace
#     fedora-bootc as the FROM image here, giving us hardened/minimal content.
#   - bootc: handles OS deployment, atomic updates, and rollback semantics.
#     The image is consumed by `bootc switch`, `bootc upgrade`, and
#     bootc-image-builder for disk image generation.
#
# Build: podman build -f images/atomic-base/Containerfile -t atomic-linux:latest .
# Test:  bootc-image-builder --type qcow2 atomic-linux:latest

# TODO: Replace with official Red Hat Hummingbird base image when published.
# Hummingbird base images will provide zero-CVE, minimal content out of the box.
# Tracking: https://www.redhat.com/en/blog/red-hat-hummingbird
FROM quay.io/fedora/fedora-bootc:42

LABEL org.opencontainers.image.title="Atomic Linux"
LABEL org.opencontainers.image.description="Free, minimal, container-optimized bootable Linux"
LABEL org.opencontainers.image.vendor="Atomic OS Project"
LABEL org.opencontainers.image.source="https://github.com/tichomir/my-atomic"
LABEL org.opencontainers.image.licenses="MIT"
LABEL containers.bootc="1"

# Install cloud-ready packages and remove unnecessary ones
RUN dnf -y install \
    cloud-init \
    chrony \
    tuned \
    audit \
    policycoreutils \
    policycoreutils-python-utils \
    selinux-policy-targeted \
    && dnf -y remove \
    NetworkManager-tui \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# Enable cloud-init on boot
RUN ln -s ../cloud-init.target \
    /usr/lib/systemd/system/default.target.wants/cloud-init.target || true

# Enable audit daemon
RUN systemctl enable auditd.service || true

# Enable chrony for time sync
RUN systemctl enable chronyd.service || true

# Mask units that are irrelevant or harmful on an immutable OS:
#   dkms.service               — DKMS can never build modules on a read-only composefs
#                                 rootfs; it always fails and pollutes `systemctl --failed`.
#   NetworkManager-wait-online — Times out on VMs / cloud instances, delays boot, and
#                                 is not required by any atomic service.
RUN systemctl mask dkms.service NetworkManager-wait-online.service \
                   falcoctl-artifact-follow.service
# falcoctl-artifact-follow auto-downloads Falco rules from the Falco Hub and
# overwrites /etc/falco/rules.d/ — which clobbers our custom agent rules.
# We manage our own rules (deployed by the COPY below), so this must be masked.

# Copy OS-layer configuration into the image
COPY os/usr /usr
COPY os/etc /etc

# Deploy our Falco configuration.
# This overwrites the RPM-installed /etc/falco/falco.yaml with our version
# (engine: modern_ebpf, our rules files, webhook to atomicagentd).
# Rules go to /etc/falco/rules.d/ which is the drop directory for Falco 0.38+.
COPY runtime/falco/falco.yaml /etc/falco/falco.yaml
COPY runtime/falco/rules/ /etc/falco/rules.d/

# SELinux: label agent exec scripts as bin_t so atomicagentd's DynamicUser
# processes (running in init_t domain) can execute them without AVC denials.
# restorecon is called by atomicagentd at agent-registration time to apply this.
RUN semanage fcontext -a -t bin_t '/var/lib/atomic/agents/[^/]+/[^/]+'

# Validate that this is a valid bootc image
RUN bootc container lint

# Image version label (overridden by CI)
ARG BUILD_VERSION=dev
LABEL org.opencontainers.image.version="${BUILD_VERSION}"
