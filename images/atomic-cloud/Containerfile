# Atomic Linux - Cloud Image
# Extends atomic-base with cloud-provider tooling.
# Target: AWS, GCP, Azure cloud deployments.
#
# Build: podman build -f images/atomic-cloud/Containerfile -t atomic-cloud:latest .

ARG BASE_IMAGE=ghcr.io/tichomir/atomic-linux:latest
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.title="Atomic Linux Cloud"
LABEL org.opencontainers.image.description="Atomic Linux optimized for cloud deployments"

# Cloud provider agents and tooling
RUN dnf -y install \
    amazon-ec2-utils \
    google-compute-engine-tools \
    && dnf clean all \
    && rm -rf /var/cache/dnf || true

# Enable cloud-specific services
RUN systemctl enable cloud-config.service \
    cloud-final.service \
    cloud-init-local.service || true

ARG BUILD_VERSION=dev
LABEL org.opencontainers.image.version="${BUILD_VERSION}"
